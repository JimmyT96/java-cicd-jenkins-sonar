pipeline {
    agent any
    tools { maven "maven3.9.6" }
    
    stages {
        stage('Build') {
            steps {
                git credentialsId: 'Githubcredentials', url: 'https://github.com/JimmyT96/java-cicd-jenkins-sonar'
                sh "mvn clean package"
            }
        }
        stage('SonarQube') {
            steps {
                withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                    sh "mvn sonar:sonar -Dsonar.login=$SONAR_TOKEN"
                }
            }
        }
        stage('Deploy to Tomcat') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'Tomcat-credentials', passwordVariable: 'PASS', usernameVariable: 'USER')]) {
                    sh """
                        curl -f -u $USER:$PASS \
                        -T target/*.war \
                        "http://18.182.36.207:8080/manager/text/deploy?path=/maven-web-app&update=true"
                    """
                }
            }
        }
    }
}
